# =============================================================================
# SWE-Squad — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & credentials — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
.last_public_sync
*.pem
*.key
*.p12
*.pfx
id_rsa*
id_ed25519*
id_ecdsa*
*.pub
credentials.json
secrets.json
service_account*.json
auth_token*
*_token.txt

# -----------------------------------------------------------------------------
# Internal docs — architecture notes, planning docs, roadmaps
# docs/ is intentionally tracked for MkDocs GitHub Pages site
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Runtime data — tickets, logs, cache
# -----------------------------------------------------------------------------
data/
logs/
*.log
*.sqlite
*.db
tickets.json
swe_progress.txt

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
pip-wheel-metadata/
.installed.cfg
MANIFEST

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/
nosetests.xml
*.cover

# -----------------------------------------------------------------------------
# Type checkers & linters
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# OS artefacts
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Temp & scratch
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.backup
*.orig
scratch/
.claude/worktrees/
