# =============================================================================
# SWE-Squad — Environment Configuration
# Drop this file as `.env` in the project root (~/SWE-Squad/.env)
# The runner loads it automatically via python-dotenv on startup.
# =============================================================================

# -----------------------------------------------------------------------------
# Core — Kill Switch & Config
# -----------------------------------------------------------------------------
SWE_TEAM_ENABLED=true
SWE_TEAM_CONFIG=/home/agent/SWE-Squad/config/swe_team.yaml

# -----------------------------------------------------------------------------
# Team Identity — scopes tickets and GitHub issue assignment
# Each SWE team gets a unique ID and dedicated GitHub account
# -----------------------------------------------------------------------------
SWE_TEAM_ID=swe-squad-1
SWE_GITHUB_ACCOUNT=your_github_bot_account
SWE_GITHUB_REPO=owner/repo-name

# -----------------------------------------------------------------------------
# GitHub (gh CLI authentication)
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, read:org
# Used for: issue creation, commenting, fetching assigned tickets
# -----------------------------------------------------------------------------
GH_TOKEN=your_github_pat_here

# -----------------------------------------------------------------------------
# Telegram Notifications
# Create a bot via @BotFather, get the chat ID via @userinfobot
# Used for: HIGH/CRITICAL alerts, HITL escalation, daily summaries
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# -----------------------------------------------------------------------------
# A2A Hub (inter-agent communication)
# Leave as localhost if running SWE-Squad standalone on this VM
# -----------------------------------------------------------------------------
A2A_HUB_URL=http://localhost:18790

# -----------------------------------------------------------------------------
# Anthropic / Claude (if invoking API directly rather than CLI)
# The runner uses the `claude` CLI by default — set this only if needed
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# -----------------------------------------------------------------------------
# Remote Worker Log Collection (SSH/rsync)
# Workers listed in config/swe_team.yaml under monitor.remote_workers
# Ensure the VM's SSH key is authorized on each worker
# -----------------------------------------------------------------------------
# SSH_IDENTITY_FILE=/home/agent/.ssh/openclaw_key

# -----------------------------------------------------------------------------
# Supabase (optional — replaces JSON ticket store)
# Leave blank to use the default JSON file store
# -----------------------------------------------------------------------------
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_supabase_anon_or_service_key
